# Telegram Bot
BOT_TOKEN=your_bot_token_from_botfather
MONGO_URI=mongodb://localhost:27017/songbot
ADMIN_IDS=123456789,987654321

# Suno API (Kie.ai) - получить на https://kie.ai/api-key
SUNO_API_KEY=your_suno_api_key
# URL для webhook (используй ngrok для локальной разработки)
SUNO_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app/webhook/suno

# Порт webhook сервера
PORT=3000
